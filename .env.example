# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_COMMIT_SHA=local
APP_ENV=development
# Server-only HMAC secret signing the short-lived quick-start cookie (Phase 3.1/3.2).
# Generate with: openssl rand -base64 32
SIGNUP_COOKIE_SECRET=

# --- Supabase ---
# Project URL and publishable key are safe to expose client-side with RLS.
# The secret key is server-only — never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Stripe ---
# Use test-mode keys in development. Live keys live in production env only.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cloudflare image uploads (Phase 3.5) ---
# Public base URL of the R2 uploads bucket (or its custom domain). Cleaned image URLs are
# built as <base>/<key_final>. The R2 bucket + Queue + container worker live in image-processor/.
NEXT_PUBLIC_UPLOADS_BASE_URL=

# --- Cloudflare Email Service ---
# Sending uses the EMAIL Worker binding from wrangler.jsonc.
CLOUDFLARE_EMAIL_FROM=
CLOUDFLARE_EMAIL_FROM_NAME=Stoop
# Physical mailing address for the transactional email footer (CASL/CAN-SPAM). Optional in dev;
# rendered only when set.
STOOP_MAILING_ADDRESS=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Integration tests (RLS / tenant isolation) ---
# Read by tests/integration via .env.local (or CI job env). Point at the Supabase project
# the RLS suite should run against. The service-role key is required to seed fixtures.
# Falls back to local-supabase defaults when unset.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: rate limiting / abuse ---
# Magic-link rate limiting uses the RATE_LIMIT_KV Cloudflare KV binding (wrangler.jsonc).
# Drop emails use the same binding for per-store and platform-wide daily windows.
# Anon order/subscribe flows (Phase 9.3) also use RATE_LIMIT_KV for per-minute (ip, store) caps.
DROP_PLATFORM_DAILY_LIMIT=5000

# --- Cloudflare Turnstile (Phase 9.3) ---
# Soft challenge on the anon order + subscribe forms. When both are unset, the widget renders
# nothing and server-side verification fails open (fine for local dev). Set both in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
