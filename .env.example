# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# --- Supabase ---
# Project URL and anon key are safe to expose client-side.
# The service role key is server-only — never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Use test-mode keys in development. Live keys live in production env only.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Optional: rate limiting / abuse ---
# Upstash Redis or Cloudflare KV credentials, if added in Phase 9
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
