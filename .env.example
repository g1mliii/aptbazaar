# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_COMMIT_SHA=local
APP_ENV=development

# --- Supabase ---
# Project URL and publishable key are safe to expose client-side with RLS.
# The secret key is server-only — never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Stripe ---
# Use test-mode keys in development. Live keys live in production env only.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cloudflare Email Service ---
# Sending uses the EMAIL Worker binding from wrangler.jsonc.
CLOUDFLARE_EMAIL_FROM=
CLOUDFLARE_EMAIL_FROM_NAME=Stoop

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Optional: rate limiting / abuse ---
# Upstash Redis or Cloudflare KV credentials, if added in Phase 9
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
